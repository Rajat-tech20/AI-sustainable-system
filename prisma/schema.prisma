generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id                  String   @id @default(uuid())
  name                String
  description         String
  primaryCategory     String?
  subCategory         String?
  seoTags             String[]
  sustainabilityTags  String[]
  rawAiOutput         Json?    // Stores the raw AI response for module 1
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model OrderImpact {
  id                  String   @id @default(uuid())
  orderId             String   @unique
  estimatedPlasticSaved Float  // in kg
  carbonAvoided       Float    // in kg
  localSourcingImpact String?
  impactStatement     String   // Human-readable statement generated by AI
  rawAiOutput         Json?
  createdAt           DateTime @default(now())
}
